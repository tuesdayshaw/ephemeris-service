# Directory containing Swiss Ephemeris data files (*.se1, *.se2, ...)
EPHE_PATH=/absolute/path/to/ephe

# API key required for /v1/* endpoints. Leave empty to disable auth in dev.
API_KEY=

# Directory where snapshot cache SQLite file will be stored
CACHE_DIR=./cache

# Default IANA timezone for snapshot/aspects endpoints
TZ=America/Chicago
